# GitSync .gitignore

# Xcode 项目文件
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# Swift Package Manager 缓存
.build/
.swiftpm/
Package.resolved

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# 构建产物
DerivedData/
build/
Release/
Debug/
dist/
*.app
*.ipa
*.dmg
*.dSYM.zip
*.dSYM

# 配置文件（包含 Token 等敏感信息时排除）
# 如果需要保留本地配置，请取消注释：
# config.local.json

# GitSync 自动添加
Thumbs.db
*.swp
*~
